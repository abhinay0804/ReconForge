+        has_web = has_web or port_is_web
+        has_ssh = has_ssh or port_is_ssh
 
         print(f"[+] TCP {port} OPEN")
 
         if banner:
             print(banner)
-            product, version = extract_product_version(banner)
             if product and version:
                 software.append((product, version))
