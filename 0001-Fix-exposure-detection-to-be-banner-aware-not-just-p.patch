diff --git a/scanner/classify.py b/scanner/classify.py
new file mode 100644
index 0000000..740188e
--- /dev/null
+++ b/scanner/classify.py
@@ -0,0 +1,32 @@
+"""
+Exposure classification helpers.
+
+Kept separate from main.py so the web/SSH exposure logic can be
+unit tested without needing a live network stack or root privileges.
+"""
+
+WEB_PORTS = [80, 443, 8080, 8443, 8000, 8888]
+WEB_PRODUCTS = ["Apache", "nginx"]
+
+
+def classify_exposure(port, banner, product=None):
+    """
+    Determine whether an open port represents web or SSH exposure.
+
+    Detection is banner-aware, not purely port-based -- a service
+    running on a non-standard port (e.g. OpenSSH on 2222) is still
+    correctly flagged.
+
+    Returns (has_web, has_ssh) as booleans.
+    """
+    banner = banner or ""
+
+    has_web = (
+        port in WEB_PORTS
+        or product in WEB_PRODUCTS
+        or "HTTP" in banner.upper()
+    )
+
+    has_ssh = port == 22 or product == "OpenSSH"
+
+    return bool(has_web), bool(has_ssh)
