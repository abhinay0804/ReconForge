+++ b/tests/test_classify.py
@@ -0,0 +1,54 @@
+from scanner.classify import classify_exposure
+
+
+def test_standard_web_port_flagged():
+    has_web, has_ssh = classify_exposure(80, "")
+    assert has_web is True
+    assert has_ssh is False
+
+
+def test_standard_https_port_flagged():
+    has_web, _ = classify_exposure(443, "")
+    assert has_web is True
+
+
+def test_nonstandard_web_port_by_number():
+    # 8080 is a common alt-HTTP port, should be flagged even with no banner
+    has_web, _ = classify_exposure(8080, "")
+    assert has_web is True
+
+
+def test_web_server_on_unlisted_port_via_banner():
+    # A web server running on a totally arbitrary port should still
+    # be flagged as web exposure based on its banner content.
+    has_web, _ = classify_exposure(31337, "HTTP/1.1 200 OK\r\nServer: nginx")
+    assert has_web is True
+
+
+def test_web_server_on_unlisted_port_via_product():
+    has_web, _ = classify_exposure(9999, "some banner", product="Apache")
+    assert has_web is True
+
+
+def test_standard_ssh_port_flagged():
+    _, has_ssh = classify_exposure(22, "SSH-2.0-OpenSSH_8.9")
+    assert has_ssh is True
+
+
+def test_ssh_on_nonstandard_port_via_product():
+    # Regression test: this was the original bug -- OpenSSH running on
+    # a non-standard port was not being flagged before the fix.
+    _, has_ssh = classify_exposure(2222, "SSH-2.0-OpenSSH_7.2", product="OpenSSH")
+    assert has_ssh is True
+
+
+def test_unrelated_service_not_flagged():
+    has_web, has_ssh = classify_exposure(5432, "some random banner")
+    assert has_web is False
+    assert has_ssh is False
+
+
+def test_empty_banner_does_not_crash():
+    has_web, has_ssh = classify_exposure(12345, None)
+    assert has_web is False
+    assert has_ssh is False
diff --git a/tests/test_cve_lookup.py b/tests/test_cve_lookup.py
new file mode 100644
index 0000000..fdc5277
--- /dev/null
+++ b/tests/test_cve_lookup.py
@@ -0,0 +1,45 @@
+from scanner.cve_lookup import extract_product_version, normalize_openssh_version
+
+
+def test_extract_apache_version():
+    product, version = extract_product_version("Server: Apache/2.4.7 (Ubuntu)")
+    assert product == "Apache"
+    assert version == "2.4.7"
+
+
+def test_extract_nginx_version():
+    product, version = extract_product_version("Server: nginx/1.18.0")
+    assert product == "nginx"
+    assert version == "1.18.0"
+
+
+def test_extract_openssh_version():
+    product, version = extract_product_version("SSH-2.0-OpenSSH_7.2")
+    assert product == "OpenSSH"
+    assert version == "7.2"
+
+
+def test_extract_openssh_version_with_patch_suffix():
+    product, version = extract_product_version("SSH-2.0-OpenSSH_6.6.1p1")
+    assert product == "OpenSSH"
+    assert version == "6.6.1p1"
+
+
+def test_extract_returns_none_for_empty_banner():
+    product, version = extract_product_version("")
+    assert product is None
+    assert version is None
+
+
+def test_extract_returns_none_for_unrecognized_banner():
+    product, version = extract_product_version("HTTP/1.1 200 OK\r\nServer: MysteryServer/9.9")
+    assert product is None
+    assert version is None
+
+
+def test_normalize_openssh_version_strips_patch_suffix():
+    assert normalize_openssh_version("6.6.1p1") == "6.6.1"
+
+
+def test_normalize_openssh_version_leaves_clean_version_untouched():
+    assert normalize_openssh_version("8.9") == "8.9"
