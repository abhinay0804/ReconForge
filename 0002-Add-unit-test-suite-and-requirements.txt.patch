+from unittest.mock import patch
+from utils.validator import validate_target
+
+
+def test_valid_hostname_resolves():
+    with patch("socket.gethostbyname", return_value="93.184.216.34"):
+        assert validate_target("example.com") is True
+
+
+def test_unresolvable_hostname_returns_false():
+    with patch("socket.gethostbyname", side_effect=OSError("no such host")):
+        assert validate_target("not-a-real-domain.invalid") is False
+
+
+def test_valid_ip_address_resolves():
+    with patch("socket.gethostbyname", return_value="127.0.0.1"):
+        assert validate_target("127.0.0.1") is True
